# =============================================================================
# Local development — copy to .env and fill in real values
#   cp .env.example .env
# For Render production, use .env.render.example → Render Dashboard
# =============================================================================

NODE_ENV=development
PORT=5000

# MongoDB Atlas (same cluster as production is fine for testing)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/aarambh?retryWrites=true&w=majority

# JWT — generate: openssl rand -base64 48
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Gmail OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password

# CORS — * allows Expo Go on any device on your LAN
CLIENT_URL=*

ADMIN_EMAIL=admin@aarambh.com
ADMIN_PASSWORD=admin123

# Local keep-alive off (Render sets KEEP_ALIVE_ENABLED automatically)
KEEP_ALIVE_ENABLED=false
