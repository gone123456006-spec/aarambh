# =============================================================================
# Local development — copy to .env and fill in real values
# =============================================================================

NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/aarambh?retryWrites=true&w=majority

JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=365d

# Brevo API (recommended — no SMTP IP whitelist issues)
BREVO_API_KEY=your_xkeysib_api_key
SMTP_FROM=your_verified_sender@gmail.com
BREVO_SENDER_NAME=Ohm's English

# Optional SMTP fallback — https://app.brevo.com → SMTP & API
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_login@smtp-brevo.com
SMTP_PASS=your_brevo_smtp_key

CLIENT_URL=*

# Admin dashboard login (User ID + password — not Gmail)
ADMIN_USERNAME=Aarambh@12342
ADMIN_PASSWORD=your_admin_password
ADMIN_DB_EMAIL=aarambh-admin@system.local
ADMIN_TOKEN_EXPIRY=24h

KEEP_ALIVE_ENABLED=false
