{
  "name": "aarambh-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for Aarambh English learning application",
  "main": "server.js",
  "scripts": {
    "validate-env": "node scripts/validate-env.js",
    "prestart": "node scripts/validate-env.js",
    "start": "node server.js",
    "free-port": "node scripts/free-port.js 5000",
    "dev": "nodemon server.js",
    "dev:clean": "node scripts/free-port.js 5000 && nodemon server.js",
    "dev:firewall": "powershell -ExecutionPolicy Bypass -File scripts/open-firewall.ps1"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.2.0",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.13",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true
}
