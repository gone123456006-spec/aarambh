# =============================================================================
# Render.com — copy each key into Dashboard → your Web Service → Environment
# Do NOT commit real secrets. Generate JWT secrets: openssl rand -base64 48
# =============================================================================

NODE_ENV=production

# Render sets PORT automatically — do not override unless you know why.
# PORT=10000

# --- Database (MongoDB Atlas) ---
# Atlas → Network Access → allow 0.0.0.0/0 (or Render outbound IPs)
# Connection string example:
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/aarambh?retryWrites=true&w=majority

# --- Auth (required) — use long random strings ---
JWT_ACCESS_SECRET=replace_with_openssl_rand_base64_48
JWT_REFRESH_SECRET=replace_with_another_openssl_rand_base64_48
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Gmail OTP (required on Render) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password_no_spaces

# --- CORS / mobile app ---
# Expo/React Native: use * so phones without a browser Origin can call the API.
CLIENT_URL=*

# --- Admin (create user in MongoDB with role: "admin", or promote after first OTP login) ---
ADMIN_EMAIL=admin@aarambh.com
ADMIN_PASSWORD=change_me_after_deploy

# --- Render keep-alive (optional; auto-enabled when RENDER=true) ---
# RENDER_EXTERNAL_URL is injected by Render — you do not set it manually.
KEEP_ALIVE_ENABLED=true

# =============================================================================
# After deploy, set in frontend/.env (phones anywhere):
# EXPO_PUBLIC_REMOTE_API_URL=https://YOUR-SERVICE-NAME.onrender.com
# =============================================================================
