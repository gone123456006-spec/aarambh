# ─── Render production (two phones / any network) ─────────────────────────
# Copy from frontend/.env.render.example after deploy:
# EXPO_PUBLIC_REMOTE_API_URL=https://aarambh-api.onrender.com
# See backend/RENDER_DEPLOY.md
#
# ─── Same Wi‑Fi only (local PC backend) ─────────────────────────────────────
# Run: npm run start:lan  (both phones scan QR, same Wi‑Fi as PC)
# npm run sync-api writes EXPO_PUBLIC_API_URL automatically:
# EXPO_PUBLIC_API_URL=http://192.168.1.5:5000
#
# Android emulator:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5000

EXPO_PUBLIC_API_PORT=5000
