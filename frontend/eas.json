{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.18.3"
    },
    "preview": {
      "distribution": "internal",
      "node": "20.18.3",
      "android": {
        "buildType": "apk",
        "image": "latest"
      },
      "env": {
        "EXPO_NO_CAPABILITY_SYNC": "1",
        "EXPO_PUBLIC_REMOTE_API_URL": "https://aarambh-api.onrender.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "20.18.3",
      "android": {
        "buildType": "app-bundle",
        "image": "latest",
        "resourceClass": "medium"
      },
      "env": {
        "EXPO_NO_CAPABILITY_SYNC": "1",
        "EXPO_PUBLIC_REMOTE_API_URL": "https://aarambh-api.onrender.com",
        "GRADLE_OPTS": "-Xmx4096m -XX:MaxMetaspaceSize=1024m"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal",
        "releaseStatus": "completed"
      }
    }
  }
}
