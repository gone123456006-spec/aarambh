# After backend is live on Render — copy to frontend/.env
# Replace YOUR-SERVICE with your Render service name (e.g. aarambh-api)

EXPO_PUBLIC_REMOTE_API_URL=https://YOUR-SERVICE.onrender.com
EXPO_PUBLIC_API_PORT=5000

# Optional LAN fallback when testing locally on same Wi‑Fi:
# EXPO_PUBLIC_API_URL=http://192.168.1.5:5000
