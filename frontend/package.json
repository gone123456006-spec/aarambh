{
  "name": "ohms",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "sync-api": "node ./scripts/sync-api-env.js",
    "sync-icons": "node ./scripts/sync-icons3d.js",
    "generate-splash": "node ./scripts/generate-splash-assets.js",
    "postinstall": "node ./scripts/sync-icons3d.js",
    "start": "node ./scripts/sync-api-env.js && node ./scripts/sync-icons3d.js && expo start --lan",
    "start:lan": "node ./scripts/sync-api-env.js && node ./scripts/sync-icons3d.js && expo start --lan",
    "start:2phones": "node ./scripts/sync-api-env.js && node ./scripts/sync-icons3d.js && expo start --lan",
    "start:tunnel": "node ./scripts/sync-api-env.js && node ./scripts/sync-icons3d.js && expo start --tunnel",
    "start:local": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:setup-windows": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-android-windows.ps1",
    "android:release": "powershell -ExecutionPolicy Bypass -File ./scripts/android-assemble-release.ps1",
    "build:aab": "eas build -p android --profile production",
    "submit:play": "eas submit -p android --profile production",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.35",
    "expo-av": "~16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.24",
    "expo-screen-orientation": "~9.0.8",
    "expo-speech": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
