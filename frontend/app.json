{
  "expo": {
    "name": "Ohm's",
    "slug": "ohms",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/aarambh-icon.png",
    "scheme": "ohms",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/ohms-logo-mark.png",
      "resizeMode": "contain",
      "backgroundColor": "#5c0000"
    },
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "bundleIdentifier": "com.ohms.english",
      "infoPlist": {
        "NSCameraUsageDescription": "Ohm's uses your camera only when you start video English practice with other learners.",
        "NSMicrophoneUsageDescription": "Ohm's uses your microphone for voice and video lessons you choose to use.",
        "NSPhotoLibraryUsageDescription": "Ohm's may access photos you select to share during English practice. We do not browse your gallery without permission."
      }
    },
    "android": {
      "package": "com.ohms.english",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#e60000",
        "foregroundImage": "./assets/images/aarambh-icon.png"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "androidNavigationBar": {
      "backgroundColor": "#FFFFFF",
      "barStyle": "dark-content"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/aarambh-icon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false,
            "windowSoftInputMode": "adjustResize",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildArchs": [
              "armeabi-v7a",
              "arm64-v8a"
            ]
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Ohm's uses your camera only when you start video English practice with other learners.",
          "microphonePermission": "Ohm's uses your microphone for voice and video lessons you choose to use.",
          "recordAudioAndroid": true
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/ohms-logo-mark.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#5c0000",
          "dark": {
            "backgroundColor": "#5c0000"
          }
        }
      ],
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "PORTRAIT"
        }
      ],
      "./plugins/withAndroidWindowsLongPaths",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7ff2aadf-dae7-4b7c-9024-1bd25662363e"
      }
    }
  }
}
